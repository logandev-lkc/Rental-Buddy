{
  "name": "rental-buddy-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --poll 1000",
    "build": "ng build",
    "build:gh": "BASE_HREF=${BASE_HREF:-/Rental-Buddy/} && ng build --configuration production --base-href \"$BASE_HREF\"",
    "deploy:gh": "npm run build:gh && rm -rf ../docs && mkdir -p ../docs && cp -R dist/rental-buddy-web/browser/* ../docs/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.5.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@types/leaflet": "^1.9.21",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
